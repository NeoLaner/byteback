# Maintainer: neolaner <neo.laner.official@gmail.com>
pkgname=byteback-bin
_pkgname=byteback
pkgver=0.1.0
pkgrel=1
pkgdesc='A fast TUI that reclaims disk space by sweeping regenerable build/dependency directories (node_modules, .next, target, ...)'
arch=('x86_64')
url='https://github.com/neolaner/byteback'
license=('MIT')
provides=('byteback')
conflicts=('byteback')
options=('!strip' '!debug')
# Uses the statically linked musl release tarball for maximum portability.
source=("$_pkgname-$pkgver.tar.gz::$url/releases/download/v$pkgver/byteback-x86_64-unknown-linux-musl.tar.gz"
        "LICENSE-$pkgver::$url/raw/v$pkgver/LICENSE")
# Run `updpkgsums` after a release is published to replace these with real hashes.
sha256sums=('SKIP'
            'SKIP')

package() {
    install -Dm755 "$srcdir/$_pkgname" "$pkgdir/usr/bin/$_pkgname"
    ln -s "$_pkgname" "$pkgdir/usr/bin/bb"
    install -Dm644 "$srcdir/LICENSE-$pkgver" "$pkgdir/usr/share/licenses/$_pkgname/LICENSE"
}
